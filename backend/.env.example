# Backend FacturaPro .env Example
# COPIAR ESTE ARCHIVO A .env PARA PRODUCCIÓN Y LLENAR LOS VALORES.
# ¡NUNCA SUBIR EL .env A GITHUB!

PORT=3005
DATABASE_URL="postgresql://user:password@localhost:5432/majia_os_db"
JWT_SECRET="super_secret_jwt_key_here"

# Orígenes permitidos (CORS) - Separados por comas
ALLOWED_ORIGINS="https://facturapro.radiotecpro.com,https://app.radiotecpro.com"

# SW SAPIENS - Credenciales para Timbrado CFDI 4.0
SW_SAPIENS_URL="https://services.sw.com.mx" # Usar esta URL para Producción. Para pruebas: https://services.test.sw.com.mx
SW_SAPIENS_USER="tu_correo_de_compra@empresa.com"
SW_SAPIENS_PASSWORD="tu_password_seguro"

# OMNICHAT - Integración WhatsApp
OMNICHAT_API_URL="https://omnichat.radiotecpro.com/api"
